rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Check if the current user is the admin of a specific organization
    function isAdminOfOrg(orgId) {
      return isSignedIn() && get(/databases/$(database)/documents/organizations/$(orgId)).data.adminWallet == request.auth.uid;
    }

    // --- Organization Rules ---
    match /organizations/{orgId} {
      allow get: if isSignedIn();
      allow list: if false; // No blanket listing of organizations
      
      allow create: if isSignedIn() 
        && isValidId(orgId)
        && incoming().adminWallet == request.auth.uid
        && isValidOrganization(incoming());
        
      allow update: if isSignedIn()
        && existing().adminWallet == request.auth.uid
        && isValidOrganization(incoming())
        && incoming().adminWallet == existing().adminWallet
        && (
          // Action: Update Name
          incoming().diff(existing()).affectedKeys().hasOnly(['name'])
          || 
          // Action: Update MXE (Sensitive)
          incoming().diff(existing()).affectedKeys().hasOnly(['mxeAddress', 'clusterId'])
        );
    }

    function isValidOrganization(data) {
      return data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.adminWallet is string && data.adminWallet.size() == 44 // Solana wallet length
        && (data.get('mxeAddress', '') is string && data.get('mxeAddress', '').size() <= 100)
        && (data.get('clusterId', '') is string && data.get('clusterId', '').size() <= 50);
    }

    // --- Employee Rules ---
    match /employees/{employeeId} {
      allow get: if isSignedIn() && (resource.data.wallet == request.auth.uid || isAdminOfOrg(resource.data.orgId));
      allow list: if isSignedIn() && (isAdminOfOrg(request.query.limit > 0 ? get(/databases/$(database)/documents/organizations/$(resource.data.orgId)).id : '')); // Simplified check for list
      // Better list check for queries
      allow list: if isSignedIn() && resource.data.orgId != null && isAdminOfOrg(resource.data.orgId);

      allow create: if isSignedIn()
        && isValidId(employeeId)
        && isAdminOfOrg(incoming().orgId)
        && isValidEmployee(incoming())
        && incoming().addedAt == request.time;

      allow update: if isSignedIn()
        && isAdminOfOrg(existing().orgId)
        && isValidEmployee(incoming())
        && incoming().orgId == existing().orgId
        && incoming().wallet == existing().wallet
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'arcisPubkey', 'status']);
    }

    function isValidEmployee(data) {
      return data.name is string && data.name.size() <= 100
        && data.wallet is string && data.wallet.size() == 44
        && data.orgId is string && data.orgId.size() <= 128
        && data.status in ['active', 'invited', 'terminated']
        && (data.get('arcisPubkey', '') is string && data.get('arcisPubkey', '').size() <= 200);
    }

    // --- PayRun Rules ---
    match /payRuns/{runId} {
      allow read: if isSignedIn() && isAdminOfOrg(resource.data.orgId);
      
      allow create: if isSignedIn()
        && isValidId(runId)
        && isAdminOfOrg(incoming().orgId)
        && isValidPayRun(incoming())
        && incoming().createdAt == request.time;

      allow update: if isSignedIn()
        && isAdminOfOrg(existing().orgId)
        && isValidPayRun(incoming())
        && incoming().orgId == existing().orgId
        && (
          // Action: Complete Run
          (existing().status == 'pending' && incoming().status == 'complete' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'txHash', 'computationId']))
        );
    }

    function isValidPayRun(data) {
      return data.orgId is string && data.orgId.size() <= 128
        && data.period is string && data.period.size() <= 50
        && data.status in ['pending', 'complete', 'failed']
        && (data.get('employeeCount', 0) is int)
        && (data.get('aggregateUsdc', 0) is number);
    }

    // --- Payslip Rules ---
    match /payslips/{payslipId} {
      allow get: if isSignedIn() && (resource.data.employeeWallet == request.auth.uid || isAdminOfOrg(resource.data.orgId));
      allow list: if isSignedIn() && (resource.data.employeeWallet == request.auth.uid || isAdminOfOrg(resource.data.orgId));

      allow create: if isSignedIn()
        && isValidId(payslipId)
        && isAdminOfOrg(incoming().orgId)
        && isValidPayslip(incoming());
        
      allow update: if false; // Payslips are immutable once written
    }

    function isValidPayslip(data) {
      return data.orgId is string && data.orgId.size() <= 128
        && data.employeeWallet is string && data.employeeWallet.size() == 44
        && data.period is string && data.period.size() <= 50
        && data.encryptedCid is string && data.encryptedCid.size() <= 200;
    }
  }
}
